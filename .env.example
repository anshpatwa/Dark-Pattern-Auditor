# Copy this file to ".env" and fill in your values.
# The app runs fully WITHOUT any key using the built-in heuristic engine.
# Add EITHER an Anthropic key (Claude) OR a free Google Gemini key to unlock AI + vision.

# --- Option A: Anthropic Claude (paid) — https://console.anthropic.com/ ---
ANTHROPIC_API_KEY=
DPA_MODEL=claude-opus-4-8

# --- Option B: Google Gemini (FREE, no credit card) — https://aistudio.google.com ---
# Create a key in Google AI Studio and paste it here to use the free AI engine.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Engine selection: "auto" (Claude if its key set, else Gemini if its key set, else
# heuristic), or force one of: "claude", "gemini", "heuristic".
DPA_ENGINE=auto

# Max characters of page text sent to the model (controls token cost).
DPA_MAX_TEXT_CHARS=18000

# Send a page screenshot to Claude for vision analysis (true/false).
DPA_USE_VISION=true

# Page fetch timeout in seconds.
DPA_FETCH_TIMEOUT=30

# Server host/port for the web dashboard.
DPA_HOST=127.0.0.1
DPA_PORT=8000
