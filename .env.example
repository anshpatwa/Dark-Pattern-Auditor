# Copy this file to ".env" and fill in your values.
# The app runs fully WITHOUT a key using the built-in heuristic engine,
# but an Anthropic key unlocks the AI (Claude) engine with vision analysis.

# Your Anthropic API key (https://console.anthropic.com/). Leave blank to use mock/heuristic mode.
ANTHROPIC_API_KEY=

# Claude model to use for analysis.
DPA_MODEL=claude-opus-4-8

# Engine selection: "auto" (Claude if key present, else heuristic), "claude", or "heuristic".
DPA_ENGINE=auto

# Max characters of page text sent to the model (controls token cost).
DPA_MAX_TEXT_CHARS=18000

# Send a page screenshot to Claude for vision analysis (true/false).
DPA_USE_VISION=true

# Page fetch timeout in seconds.
DPA_FETCH_TIMEOUT=30

# Server host/port for the web dashboard.
DPA_HOST=127.0.0.1
DPA_PORT=8000
